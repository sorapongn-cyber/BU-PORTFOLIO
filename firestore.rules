rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default system deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure rule-set for Fashion Posts vault contributions
    match /fashion_posts/{postId} {
      allow read, list: if true;
      
      allow create: if request.auth != null
        && request.resource.data.mediaType in ['image', 'video']
        && request.resource.data.mediaUrl is string
        && request.resource.data.mediaUrl.size() < 1048576
        && request.resource.data.location is string
        && request.resource.data.location.size() <= 300
        && request.resource.data.userEmail == request.auth.token.email
        && request.resource.data.createdAt == request.time;
        
      allow update, delete: if false;
    }
  }
}
